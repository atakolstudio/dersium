<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="dersium.db-shm"/>
        <exclude domain="database" path="dersium.db-wal"/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="dersium.db"/>
        <include domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
